generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StoryType {
  CARD
  LINE
}

model Journey {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  startingPoint String @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  altitudeInfos AltitudeInfo[]
  epics         Epic[]
  stories       Story[]
  tags          Tag[]
  translations  JourneyTranslation[]
}

model JourneyTranslation {
  id            String   @id @default(cuid())
  locale        String
  name          String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  journey   Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  journeyId String

  @@unique([journeyId, locale])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  journey   Journey  @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  journeyId String

  stories       Story[]
  altitudeInfos AltitudeInfo[]
  translations  TagTranslation[]

  @@index([journeyId])
  @@index([name])
}

model TagTranslation {
  id        String   @id @default(cuid())
  locale    String
  name      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId String

  @@unique([tagId, locale])
}

model AltitudeInfo {
  id        String   @id @default(cuid())
  title     String
  icon      String   @default("info")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  journey   Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  journeyId String
  values    AltitudeInfoValue[]
  tags      Tag[]
  translations AltitudeInfoTranslation[]

  @@index([journeyId, order])
}

model AltitudeInfoTranslation {
  id        String   @id @default(cuid())
  locale    String
  title     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  altitudeInfo   AltitudeInfo @relation(fields: [altitudeInfoId], references: [id], onDelete: Cascade)
  altitudeInfoId String

  @@unique([altitudeInfoId, locale])
}

model AltitudeInfoValue {
  id             String   @id @default(cuid())
  value          String
  startPoint     Int
  endPoint       Int
  useGradient    Boolean  @default(false)
  startValue     Float?
  endValue       Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  altitudeInfo   AltitudeInfo @relation(fields: [altitudeInfoId], references: [id], onDelete: Cascade)
  altitudeInfoId String
  translations   AltitudeInfoValueTranslation[]

  @@index([altitudeInfoId, startPoint, endPoint])
}

model AltitudeInfoValueTranslation {
  id        String   @id @default(cuid())
  locale    String
  value     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  altitudeInfoValue   AltitudeInfoValue @relation(fields: [altitudeInfoValueId], references: [id], onDelete: Cascade)
  altitudeInfoValueId String

  @@unique([altitudeInfoValueId, locale])
}

model Epic {
  id        String   @id @default(cuid())
  title     String
  description String   @default("")
  color     String   @default("#4ecdc4")
  background String  @default("{\"mode\":\"color\",\"color\":\"#4ecdc4\"}")
  backgroundImage String?
  backgroundPatternConfig Json?
  startPoint Int
  endPoint   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  journey   Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  journeyId String
  translations EpicTranslation[]

  @@index([journeyId, startPoint, endPoint])
}

model EpicTranslation {
  id          String   @id @default(cuid())
  locale      String
  title       String   @default("")
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  epic   Epic   @relation(fields: [epicId], references: [id], onDelete: Cascade)
  epicId String

  @@unique([epicId, locale])
}

model Story {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  extraContent String  @default("")
  storyType   StoryType @default(CARD)
  background  String?
  imageUrl    String?
  lineColor   String   @default("#4ecdc4")
  lineWidth   Int      @default(4)
  lineLabel   String   @default("")
  tooltipText String   @default("")
  tooltipImageUrl String?
  startPoint  Int
  endPoint    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  journey   Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  journeyId String
  tags      Tag[]
  translations StoryTranslation[]

  @@index([journeyId, startPoint, endPoint])
}

model StoryTranslation {
  id          String   @id @default(cuid())
  locale      String
  title       String   @default("")
  description String   @default("")
  extraContent String  @default("")
  lineLabel   String   @default("")
  tooltipText String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  story   Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  storyId String

  @@unique([storyId, locale])
}
