{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vertical-fe.local/schemas/story.schema.json",
  "title": "StoryImport",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "startPoint", "endPoint"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Story title displayed in the journey."
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "extraContent": {
      "type": "string",
      "description": "Optional long-form HTML or plain text."
    },
    "storyType": {
      "type": "string",
      "enum": ["CARD", "LINE"],
      "default": "CARD"
    },
    "imageUrl": {
      "type": "string"
    },
    "lineColor": {
      "type": "string",
      "default": "#4ecdc4"
    },
    "lineWidth": {
      "type": "integer",
      "minimum": 1,
      "maximum": 64,
      "default": 4
    },
    "lineLabel": {
      "type": "string",
      "default": ""
    },
    "tooltipText": {
      "type": "string",
      "default": ""
    },
    "tooltipImageUrl": {
      "type": "string"
    },
    "startPoint": {
      "type": "integer",
      "minimum": 0
    },
    "endPoint": {
      "type": "integer",
      "minimum": 0,
      "description": "Must be >= startPoint."
    },
    "tags": {
      "type": "array",
      "minItems": 0,
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 100
      },
      "default": [],
      "description": "Optional tags for filtering. 3-100 characters each, max 20 unique tags per item."
    },
    "translations": {
      "type": "object",
      "description": "Optional per-locale overrides. Keys are locale codes (e.g. \"hu\"). The source locale (\"en\") lives in the base fields and is ignored here.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "extraContent": { "type": "string" },
          "lineLabel": { "type": "string" },
          "tooltipText": { "type": "string" }
        }
      }
    }
  }
}
